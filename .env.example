# ============================================================================
# Memory Engine V2 — variables de entorno
# ============================================================================
# Todas son opcionales. Sin configurar nada, el sistema funciona en modo
# fallback (regex + hashing embeddings + Firestore real).

# --- LLM Extractor (opcional) ---
# Si configurás alguna API key, el extractor usa LLM para extraer hechos.
# Sin ninguna, usa el extractor regex (funciona, pero cubre menos casos).

GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Backend explícito. Si es "auto" (default), prueba gemini → claude → openai → regex.
# Valores válidos: auto | gemini | claude | openai | regex
LLM_EXTRACTOR_BACKEND=auto

# --- Embeddings (opcional) ---
# Si hay GEMINI_API_KEY, usa text-embedding-004 (768d). Si no, hashing determinístico.
# Valores válidos: auto | gemini | hashing
EMBEDDING_BACKEND=auto

# --- Vector Store ---
# "auto" intenta Firestore Vector Search. "memory" usa store en memoria (tests).
# Valores válidos: auto | firestore | memory
VECTOR_STORE_BACKEND=auto

# --- Firestore fake para tests ---
# Si es "true", todo Firestore es in-memory. Útil para CI.
USE_FAKE_FIRESTORE=false

# --- Panel / sesiones ---
# Hereda de la config legacy; no se cambian.
